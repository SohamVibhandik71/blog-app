<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Blog</title>
</head>
<body>

    <h1><%= currBlog.title %></h1>
    <h3>By <%= currBlog.author %></h3>
    <p><%= currBlog.content %></p>

    <hr>

    <h4>Comments:</h4>

    <% if (comments.length === 0) { %>
        <p>No comments yet</p>
    <% } %>

    <% comments.forEach(comment => { %>
        <p><%= comment.author %> : <%= comment.content %></p>
    <% }) %>

    <hr>

    <!-- Delete Blog -->
    <form action="/blogs/<%= currBlog.id %>/delete" method="POST">
        <button type="submit">Delete</button>
    </form>

    <br>

    <!-- Edit Blog -->
    <form action="/blogs/<%= currBlog.id %>/edit" method="GET">
        <button type="submit">Edit</button>
    </form>

    <hr>

    <!-- Add Comment -->
    <h4>Add Comment:</h4>

    <form action="/blogs/<%= currBlog.id %>/comments" method="POST">

        <label>Content:</label><br>
        <textarea name="content" rows="4" cols="30" required></textarea>
        <br><br>

        <label>Select User:</label><br>
        <select name="user_id" required>
            <% users.forEach(user => { %>
                <option value="<%= user.id %>">
                    <%= user.name %>
                </option>
            <% }) %>
        </select>

        <br><br>
        <button type="submit">Add Comment</button>
    </form>

</body>
</html>