<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:wght@400;600;700&family=Libre+Baskerville:wght@400;700&family=Montserrat:wght@400;500;600;700&display=swap" rel="stylesheet">
    <title>Edit Blog</title>
</head>
<body class="form-page">
    <main class="page-shell narrow-shell">
    <section class="form-panel">

    <p class="eyebrow">Refine the draft</p>
    <h1>Edit Blog</h1>

    <form action="/blogs/<%= id %>/edit" method="POST" class="stacked-form">

        <label>Title:</label>
        <input type="text" name="title" value="<%= currBlog.title %>" required>

        <label>Content:</label>
        <textarea name="content" rows="5" cols="30" required><%= currBlog.content %></textarea>

        <button type="submit">Update Blog</button>

    </form>
    </section>
    </main>

</body>
</html>
