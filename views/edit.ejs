<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Edit Blog</title>
</head>
<body>

    <h1>Edit Blog</h1>

    <form action="/blogs/<%= id %>/edit" method="POST">

        <label>Title:</label><br>
        <input type="text" name="title" value="<%= currBlog.title %>" required>
        <br><br>

        <label>Content:</label><br>
        <textarea name="content" rows="5" cols="30" required><%= currBlog.content %></textarea>
        <br><br>

        <button type="submit">Update Blog</button>

    </form>

</body>
</html>