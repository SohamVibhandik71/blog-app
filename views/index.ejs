
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <link rel="stylesheet" href="/styles.css">
    <link rel="preconnect" href="https://fonts.googleapis.com">
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
    <link href="https://fonts.googleapis.com/css2?family=JetBrains+Mono:ital,wght@0,100..800;1,100..800&family=Libre+Baskerville:ital,wght@0,400..700;1,400..700&family=Montserrat:ital,wght@0,100..900;1,100..900&family=Sacramento&family=Sekuya&display=swap" rel="stylesheet">
    <title>Home</title>
</head>
<body class="home-page">
    <main class="page-shell">
        <header class="page-header">
            <p class="eyebrow">Fresh from the desk</p>
            <h1 class="heading">Blogs</h1>
        </header>

    <ul class="blog-list">
        <% blogsList.forEach((blog, index) => { %>
            <li class="blog-card"><a href="/blogs/<%=blog.id%>" ><%= blog.title %></a></li> 
        <% }); %>
    </ul>
    <a class="primary-link" href="/blogs/new">New Blog</a>

    <section class="form-panel compact-panel">
        <h2>Add a writer</h2>
    <form action="/user" method="post" class="inline-form">
        <input type="text" name="name" placeholder="Enter User Name" required>
        <button type="submit">Add User</button>
    </form>
    </section>
    </main>
</body>
</html>
